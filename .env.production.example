# ── Dev-server (GCP) production env — copy to .env.production and fill in ──
# Lab/GNS3 is OFF for this first deploy (browse + register + content only).
# Anything left blank below keeps that feature hidden/disabled — safe to skip.

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV=production

# Public hostname Caddy issues the TLS cert for (also the cookie/HTTPS origin).
# No domain? Use nip.io with the VM's external IP (dots → dashes):
#   SITE_ADDRESS=34-101-22-7.nip.io
SITE_ADDRESS=
# Must match the public https URL exactly (used for OAuth redirects + email links)
APP_URL=https://CHANGE-ME.nip.io

# REQUIRED in prod — server refuses to start without it.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   (on the VM without node: openssl rand -hex 32)
SESSION_SECRET=

# pino level: trace|debug|info|warn|error (default: info in prod)
LOG_LEVEL=

# ── MongoDB ───────────────────────────────────────────────────────────
# Mongo is provided by the compose service; leave as-is unless using Atlas.
MONGODB_URI=mongodb://mongo:27017/pingable-dev

# ── Email (verify/reset) — optional ───────────────────────────────────
# Blank = app runs, just doesn't send mail. Works with any SMTP provider
# (SendGrid smtp.sendgrid.net:587, Gmail, Mailgun, ...).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Social login (OAuth) — optional ───────────────────────────────────
# A provider's button only shows when BOTH its CLIENT_ID and CLIENT_SECRET
# are set. Register this redirect URI in each provider console (= APP_URL + path):
#   Google   → <APP_URL>/auth/oauth/google/callback
#   Facebook → <APP_URL>/auth/oauth/facebook/callback
# NOTE: the localhost creds in your dev .env won't work here — the redirect URI
# must match the production APP_URL above, so add it in the provider console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── AI Mentor (§22) — optional ────────────────────────────────────────
# Blank = "พี่เลี้ยง AI" button hidden. Uses the Claude Messages API (Haiku tier).
ANTHROPIC_API_KEY=
MENTOR_MODEL=claude-haiku-4-5

# ── Events hub (/events) — optional ───────────────────────────────────
# Each flag lights up one event card + the "อีเวนต์" nav link. Keep duels OFF
# until labs are live (each duel burns 2 lab slots from LAB_MAX_CONCURRENT).
DUELS_ENABLED=
TIME_ATTACK_ENABLED=

# ── GNS3 / labs — leave blank for now; fill when you add GNS3 to this VM ──
# When you add GNS3 on this same VM later:
#   GNS3_HOST=http://localhost  GNS3_PORT=3080  GNS3_VYOS_TEMPLATE=<uuid>
GNS3_HOST=
GNS3_PORT=3080
# Basic auth for the GNS3 REST API — blank if GNS3 has no auth.
GNS3_USER=
GNS3_PASS=
# template_id of the registered VyOS Universal Router appliance.
GNS3_VYOS_TEMPLATE=
# Appliance console login (VyOS default is vyos/vyos).
GNS3_NODE_USER=vyos
GNS3_NODE_PASS=vyos
# Leave blank (recommended): browser reaches the GNS3 Web-UI through our own
# auth-checked proxy, so GNS3 never needs to be exposed to the internet. Set
# only to let the browser talk to a GNS3 origin directly (then add it to CSP).
GNS3_PUBLIC_URL=

# ── Lab cost control ──────────────────────────────────────────────────
# Idle labs with no heartbeat past this many minutes get swept (default 45).
LAB_IDLE_MINUTES=45
# Max concurrent labs system-wide (each = a real QEMU VM on the GNS3 host;
# 0 = unlimited, default 10). Over the cap, new users get a 503 to retry.
LAB_MAX_CONCURRENT=10
# Troubleshoot/duel setup-injection retry budget before latching failed (default 8).
LAB_SETUP_MAX_ATTEMPTS=8

# ── Auth ──────────────────────────────────────────────────────────────
# Lock an account for 15 min after this many wrong passwords in a row (default 10).
LOGIN_LOCK_AFTER=10
