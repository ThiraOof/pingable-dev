# ── App ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Required in production (server refuses to start without it). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── MongoDB ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pingable-dev

# ── GNS3 server (REST API ที่ฝั่ง server ใช้สร้าง/ลบ lab) ─────────────
GNS3_HOST=http://localhost
GNS3_PORT=3080
# Basic auth — เว้นว่างถ้า GNS3 ไม่ได้เปิด auth
GNS3_USER=
GNS3_PASS=

# เว้นว่างไว้ (แนะนำ): เบราว์เซอร์เข้า GNS3 Web-UI ผ่าน proxy ของเราเอง
# (/static/web-ui/...) ซึ่งตรวจสิทธิ์ว่าแตะได้เฉพาะ lab ของตัวเอง — GNS3 ไม่ต้อง
# expose ออกอินเทอร์เน็ตเลย ตั้งค่านี้เฉพาะเมื่อต้องการให้เบราว์เซอร์คุยกับ GNS3
# origin ตรง ๆ (ข้าม proxy); ถ้าตั้ง ต้องเพิ่ม origin นี้ใน CSP frame-src ด้วย
GNS3_PUBLIC_URL=

# ── VyOS appliance (ใช้ใน lab ของคอร์ส Enterprise Networking) ────────
# template_id ของ VyOS Universal Router ที่ลงทะเบียนไว้บน GNS3 server
# (ดูวิธีใน CLAUDE.md หัวข้อ "VyOS appliance for configuration labs")
GNS3_VYOS_TEMPLATE=
# Console login ของ appliance (VyOS default คือ vyos/vyos)
GNS3_NODE_USER=vyos
GNS3_NODE_PASS=vyos

# ── Lab cost control ──────────────────────────────────────────────────
# Lab ที่ไม่มี heartbeat นานเกินค่านี้ (นาที) จะถูก sweeper ปิดอัตโนมัติ
LAB_IDLE_MINUTES=45
# จำนวน lab ที่รันพร้อมกันได้ทั้งระบบ (ทุก lab = QEMU VM จริงบน GNS3 host —
# ตั้งตาม RAM ที่มี เช่น VyOS 1 ตัว ≈ 512MB) เกินแล้วผู้ใช้ใหม่ได้ 503 ให้รอ
# ใส่ 0 = ไม่จำกัด (default: 10)
LAB_MAX_CONCURRENT=10
# โจทย์ troubleshoot/duel: จำนวนครั้งที่ "จัดฉากโจทย์" (inject config) ล้มได้ก่อน
# ยอมแพ้ถาวร — เผื่อ config daemon ของ VyOS ยังไม่พร้อมตอนเพิ่งบูต (duel บูตหลายตัว
# พร้อมกันยิ่งช้า) ตั้งสูงขึ้นถ้า host ช้า (default: 8)
LAB_SETUP_MAX_ATTEMPTS=8

# ── Auth ──────────────────────────────────────────────────────────────
# ล็อกบัญชี 15 นาทีหลังใส่รหัสผ่านผิดติดกันครบจำนวนนี้ (กัน brute-force รายบัญชี)
LOGIN_LOCK_AFTER=10

# ── Social login (OAuth) — optional ───────────────────────────────────
# ปุ่ม "ดำเนินการต่อด้วย Google" จะโผล่บนหน้า login/register เฉพาะเมื่อ
# ตั้งครบทั้ง CLIENT_ID และ CLIENT_SECRET ของ provider นั้น (ไม่ตั้ง = ซ่อนปุ่ม).
# Redirect URI ที่ต้องลงทะเบียนในคอนโซลของแต่ละ provider = APP_URL + เส้นทางนี้:
#   Google   → <APP_URL>/auth/oauth/google/callback
# (Apple ยังไม่รองรับ — โครงสร้างเตรียมไว้แล้วใน src/config/oauth.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Email verification ────────────────────────────────────────────────
# หากไม่ตั้งค่า SMTP_HOST server จะยังทำงานปกติ แต่จะไม่ส่งอีเมลยืนยัน (warn ใน log)
# ใช้ได้กับทุก SMTP provider เช่น SendGrid (smtp.sendgrid.net:587), Gmail, Mailgun
APP_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Logging ───────────────────────────────────────────────────────────
# pino level: trace|debug|info|warn|error (default: debug in dev, info in prod)
LOG_LEVEL=

# ── AI Mentor (§22, optional) ─────────────────────────────────────────
# Set to enable the Socratic "พี่เลี้ยง AI" button on failed grades. Unset =
# feature hidden. Uses the Claude Messages API (fast/cheap Haiku tier);
# rate-limited to 5 calls/lab/day per user. MENTOR_MODEL overrides the model.
ANTHROPIC_API_KEY=
MENTOR_MODEL=claude-haiku-4-5

# ── Events hub (/events) ──────────────────────────────────────────────
# Each flag below lights up one event card on /events and the "อีเวนต์" nav
# link (shown only when at least one event is live). See src/config/events.js.
#
# Lab Duel (§14): head-to-head duels. Each duel consumes 2 lab slots from
# LAB_MAX_CONCURRENT, so keep it off outside scheduled events.
DUELS_ENABLED=
# Time Attack: stub event (UI lights up but the flow isn't built yet).
TIME_ATTACK_ENABLED=
