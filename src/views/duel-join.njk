{% extends "base.njk" %}
{% block title %}เข้าร่วมดวล — Pingable{% endblock %}

{% block content %}
<div class="duel-wrap">
  <div class="duel-cta-card duel-join-card">
    <div class="duel-vs-emoji">⚔️</div>
    <h2>{{ duel.host.username }} ท้าดวลคุณ!</h2>
    <p>โจทย์: <strong>{{ duel.labTitle }}</strong> (โหมดซ่อม)</p>
    <p class="duel-join-note">กดเข้าร่วมแล้วเริ่มแข่งทันที — ใครซ่อมผ่าน 100% ก่อนชนะ</p>
    <form method="POST" action="/duel/{{ duel._id }}/join" id="joinForm">
      <button type="submit" class="btn btn-primary btn-lg">เข้าร่วมดวล</button>
    </form>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script type="module">
  document.getElementById('joinForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button'); btn.disabled = true; btn.textContent = 'กำลังเข้าร่วม…';
    try {
      const r = await fetch(e.target.action, { method: 'POST' });
      const d = await r.json();
      if (!d.ok) throw new Error(d.error || 'เข้าร่วมไม่สำเร็จ');
      location.href = '/duel/{{ duel._id }}';
    } catch (err) { btn.disabled = false; btn.textContent = 'ลองใหม่'; alert(err.message); }
  });
</script>
{% endblock %}
