{% extends "base.njk" %}
{% block title %}คอร์สเรียน — Pingable{% endblock %}

{% block content %}
<png-page-header title="คอร์สเรียนทั้งหมด" subtitle="เรียนรู้องค์ความรู้เครือข่าย พร้อมลงมือทำ Lab บน Topology จริง — ไล่ระดับตั้งแต่เริ่มต้นจนถึงผู้เชี่ยวชาญ"></png-page-header>

<div class="catalog-search-wrap">
  <input type="search" id="course-search" class="catalog-search" placeholder="ค้นหาคอร์ส..." autocomplete="off" spellcheck="false">
</div>

{% for lane in lanes %}
<png-level-lane label="{{ lane.label }}" level="{{ lane.key }}" count="{{ lane.courses | length }}">
  {% for c in lane.courses %}
  {% set course = c.doc %}
  <png-course-card
    href="/courses/{{ course._id }}"
    title="{{ course.title }}"
    desc="{{ course.description }}"
    level="{{ course.level }}"
    {% if course.track %}track="{{ course.track }}"{% endif %}
    percent="{{ c.percent }}"
    modules="{{ c.moduleCount }}"
    readings="{{ c.counts.readings or 0 }}"
    labs="{{ c.counts.labs or 0 }}"
    quizzes="{{ c.counts.quizzes or 0 }}"
    hours="{{ course.estimatedHours or 0 }}"
    {% if c.lessonTotal == 0 %}soon{% endif %}></png-course-card>
  {% endfor %}
</png-level-lane>
{% else %}
<div class="empty-state">
  <p>ยังไม่มีคอร์สเรียนในขณะนี้ กรุณากลับมาตรวจสอบอีกครั้ง</p>
</div>
{% endfor %}
{% endblock %}

{% block scripts %}<script type="module" src="/js/ui.js"></script>{% endblock %}
