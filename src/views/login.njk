{% extends "base.njk" %}
{% block title %}เข้าสู่ระบบ — Pingable{% endblock %}

{% block content %}
<png-auth>
  <aside class="auth-brand">
    <png-eyebrow live>Pingable</png-eyebrow>
    <h2>กลับมาทำ Lab ต่อกันเลย</h2>
    <p>เข้าสู่ระบบเพื่อ provision Topology, ทำโจทย์ และตรวจคำตอบบนอุปกรณ์จริง</p>
    <png-terminal title="auth — session">
      <p><span class="prompt">$</span> ssh you@pingable.dev</p>
      <p class="out">Authenticating session...</p>
      <p class="out"><span class="ok">✓ welcome back</span></p>
      <p><span class="prompt">$</span> <span class="cursor">_</span></p>
    </png-terminal>
  </aside>

  <div class="auth-card">
    <h2>เข้าสู่ระบบ</h2>
    <p class="auth-sub">ยินดีต้อนรับกลับ — เข้าสู่ระบบเพื่อทำ Lab ต่อ</p>
    {% if info %}
      <div class="alert alert-success">{{ info }}</div>
    {% endif %}
    {% if error %}
      <div class="alert alert-error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/auth/login">
      <div class="form-group">
        <label for="email">อีเมล</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
      </div>
      <div class="form-group">
        <div class="auth-link-row">
          <label for="password">รหัสผ่าน</label>
          <a href="/auth/forgot-password" tabindex="-1">ลืมรหัสผ่าน?</a>
        </div>
        <div class="pw-wrap">
          <input type="password" id="password" name="password" required placeholder="••••••••" autocomplete="current-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="password">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block" data-submit>เข้าสู่ระบบ</button>
    </form>
    <p class="auth-link">ยังไม่มีบัญชี? <a href="/auth/register">สมัครสมาชิก</a></p>
  </div>
</png-auth>
{% endblock %}

{% block scripts %}<script type="module" src="/js/auth.js"></script>{% endblock %}
