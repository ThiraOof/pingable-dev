{% extends "base.njk" %}
{% block title %}ตั้งรหัสผ่านใหม่ — Pingable{% endblock %}

{% block content %}
<png-auth>
  <aside class="auth-brand">
    <png-eyebrow live>Pingable</png-eyebrow>
    <h2>ตั้งรหัสผ่านใหม่</h2>
    <p>เลือกรหัสผ่านใหม่ที่จำง่ายสำหรับคุณ แต่เดายากสำหรับคนอื่น แล้วกลับไปทำ Lab ต่อได้เลย</p>
    <png-terminal title="auth — reset">
      <p><span class="prompt">$</span> passwd --reset</p>
      <p class="out">Verifying recovery token...</p>
      <p class="out"><span class="ok">✓ token valid — set a new password</span></p>
      <p><span class="prompt">$</span> <span class="cursor">_</span></p>
    </png-terminal>
  </aside>

  <div class="auth-card">
    <h2>ตั้งรหัสผ่านใหม่</h2>
    <p class="auth-sub">รหัสผ่านอย่างน้อย 8 ตัวอักษร และมีตัวอักษรกับตัวเลขอย่างน้อยอย่างละ 1 ตัว</p>
    {% if error %}
      <div class="alert alert-error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/auth/reset-password">
      <input type="hidden" name="token" value="{{ token }}">
      <div class="form-group">
        <label for="password">รหัสผ่านใหม่</label>
        <div class="pw-wrap">
          <input type="password" id="password" name="password" required placeholder="อย่างน้อย 8 ตัวอักษร" minlength="8" autocomplete="new-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="password">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label for="confirmPassword">ยืนยันรหัสผ่านใหม่</label>
        <div class="pw-wrap">
          <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••" autocomplete="new-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="confirmPassword">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block" data-submit>บันทึกรหัสผ่านใหม่</button>
    </form>
    <p class="auth-link">นึกรหัสผ่านเดิมออกแล้ว? <a href="/auth/login">เข้าสู่ระบบ</a></p>
  </div>
</png-auth>
{% endblock %}

{% block scripts %}<script type="module" src="/js/auth.js"></script>{% endblock %}
