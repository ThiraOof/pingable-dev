{% extends "base.njk" %}
{% block title %}{{ course.title }} — Pingable{% endblock %}

{% block content %}
<div class="course-detail-header">
  <a href="/courses" class="back-link"><png-icon name="arrow-left" size="16"></png-icon> คอร์สเรียนทั้งหมด</a>
  {% if course.track %}<png-badge variant="track">{{ course.track }}</png-badge>{% endif %}
  <png-badge variant="{{ course.level }}">{{ course.level }}</png-badge>
  <h1>{{ course.title }}</h1>
  <p>{{ course.description }}</p>

  {% if course.prerequisites.length %}
  <div class="prereq-box">
    <strong>ความรู้พื้นฐานที่ควรมี:</strong>
    <ul>{% for p in course.prerequisites %}<li>{{ p }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
</div>

<div class="course-progress-bar">
  <png-progress-ring percent="{{ percent }}" size="64"></png-progress-ring>
  <div class="cpb-meta">
    <strong>ความคืบหน้าของคุณ</strong>
    <p>{{ doneTotal }} / {{ lessonTotal }} บทเรียนสำเร็จ
       {% if course.estimatedHours %}· ใช้เวลาทั้งหมด ~{{ course.estimatedHours }} ชั่วโมง{% endif %}</p>
  </div>
  {% if nextUp %}
  <png-button variant="primary" href="/learn/{{ course._id }}/{{ nextUp.m }}/{{ nextUp.l }}" icon-end="arrow-right">
    {% if doneTotal > 0 %}เรียนต่อ{% else %}เริ่มเรียน{% endif %}
  </png-button>
  {% endif %}
</div>

<png-modules course-id="{{ course._id }}">
  <script type="application/json">
{ "modules": [
{% for mb in modules %}
  { "title": {{ mb.mod.title | dump | safe }},
    "description": {{ (mb.mod.description or "") | dump | safe }},
    "doneCount": {{ mb.doneCount }}, "total": {{ mb.total }}, "percent": {{ mb.percent }},
    "objectives": {{ (mb.mod.objectives or []) | dump | safe }},
    "lessons": [
    {% for lr in mb.lessons -%}
      { "m": {{ lr.m }}, "l": {{ lr.l }}, "type": {{ lr.lesson.type | dump | safe }},
        "title": {{ lr.lesson.title | dump | safe }},
        "completed": {{ "true" if lr.completed else "false" }},
        "nodeCount": {{ (lr.lesson.topology.nodes | length) if lr.lesson.topology and lr.lesson.topology.nodes else 0 }},
        "qCount": {{ (lr.lesson.questions | length) if lr.lesson.questions else 0 }},
        "estMinutes": {{ lr.lesson.estMinutes or 0 }} }{{ "," if not loop.last }}
    {%- endfor %}
    ] }{{ "," if not loop.last }}
{% endfor %}
] }
  </script>
</png-modules>
{% endblock %}
