{% extends "base.njk" %}
{% block title %}สมัครสมาชิก — Pingable{% endblock %}

{% block content %}
<png-auth>
  <aside class="auth-brand">
    <png-eyebrow live>Pingable</png-eyebrow>
    <h2>เริ่มต้นเส้นทาง Network Engineer</h2>
    <p>สร้างบัญชีฟรี แล้วฝึกทำ Lab บน Router/Switch จริงผ่านเบราว์เซอร์ พร้อมระบบตรวจคำตอบอัตโนมัติ</p>
    <png-terminal title="onboarding">
      <p><span class="prompt">$</span> create-account --free</p>
      <p class="out">Provisioning your workspace...</p>
      <p class="out"><span class="ok">✓ ready to learn</span></p>
      <p><span class="prompt">$</span> <span class="cursor">_</span></p>
    </png-terminal>
  </aside>

  <div class="auth-card">
    <h2>สมัครสมาชิก</h2>
    <p class="auth-sub">สร้างบัญชีฟรี แล้วเริ่มฝึกทำ Network Lab ได้ทันที</p>
    {% if error %}
      <div class="alert alert-error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/auth/register">
      <div class="form-group">
        <label for="username">ชื่อผู้ใช้</label>
        <input type="text" id="username" name="username" required placeholder="network_hero" autocomplete="username">
      </div>
      <div class="form-group">
        <label for="email">อีเมล</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
      </div>
      {% if goals %}
      <div class="form-group">
        <label for="goal">เป้าหมายของคุณ <span class="field-optional">(ไม่บังคับ — เราจะเรียงคอร์สแนะนำให้ตรงทาง)</span></label>
        <select id="goal" name="goal">
          <option value="">— เลือกเป้าหมาย —</option>
          {% for key, g in goals %}
          <option value="{{ key }}">{{ g.label }}</option>
          {% endfor %}
        </select>
      </div>
      {% endif %}
      <div class="form-group">
        <label for="password">รหัสผ่าน</label>
        <div class="pw-wrap">
          <input type="password" id="password" name="password" required placeholder="อย่างน้อย 8 ตัวอักษร" minlength="8" autocomplete="new-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="password">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label for="confirmPassword">ยืนยันรหัสผ่าน</label>
        <div class="pw-wrap">
          <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••" autocomplete="new-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="confirmPassword">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block" data-submit>สมัครสมาชิก</button>
    </form>
    {% include "_oauth-buttons.njk" %}
    <p class="auth-link">มีบัญชีแล้ว? <a href="/auth/login">เข้าสู่ระบบ</a></p>
  </div>
</png-auth>
{% endblock %}

{% block scripts %}<script type="module" src="/js/auth.js"></script>{% endblock %}
