{% extends "base.njk" %}
{% block title %}สมัครสมาชิก — Pingable Dev{% endblock %}

{% block content %}
<div class="auth-split">
  <aside class="auth-brand">
    <span class="eyebrow"><span class="dot-live"></span> Pingable Dev</span>
    <h2>เริ่มต้นเส้นทาง Network Engineer</h2>
    <p>สร้างบัญชีฟรี แล้วฝึกทำ Lab บน Router/Switch จริงผ่านเบราว์เซอร์ พร้อมระบบตรวจคำตอบอัตโนมัติ</p>
    <div class="terminal-preview">
      <div class="terminal-bar">
        <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
        <span class="terminal-title">onboarding</span>
      </div>
      <div class="terminal-body">
        <p><span class="prompt">$</span> create-account --free</p>
        <p class="out">Provisioning your workspace...</p>
        <p class="out"><span class="ok">✓ ready to learn</span></p>
        <p><span class="prompt">$</span> <span class="cursor">_</span></p>
      </div>
    </div>
  </aside>

  <div class="auth-card">
    <h2>สมัครสมาชิก</h2>
    <p class="auth-sub">สร้างบัญชีฟรี แล้วเริ่มฝึกทำ Network Lab ได้ทันที</p>
    {% if error %}
      <div class="alert alert-error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/auth/register">
      <div class="form-group">
        <label for="username">ชื่อผู้ใช้</label>
        <input type="text" id="username" name="username" required placeholder="network_hero">
      </div>
      <div class="form-group">
        <label for="email">อีเมล</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label for="password">รหัสผ่าน</label>
        <input type="password" id="password" name="password" required placeholder="อย่างน้อย 8 ตัวอักษร" minlength="8">
      </div>
      <div class="form-group">
        <label for="confirmPassword">ยืนยันรหัสผ่าน</label>
        <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary btn-block">สมัครสมาชิก</button>
    </form>
    <p class="auth-link">มีบัญชีแล้ว? <a href="/auth/login">เข้าสู่ระบบ</a></p>
  </div>
</div>
{% endblock %}
