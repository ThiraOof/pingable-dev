{% extends "base.njk" %}
{% block title %}{{ lesson.title }} — Pingable{% endblock %}

{% block content %}
<div class="learn-layout">
  <article class="reading">
    <div class="reading-head">
      <a href="/courses/{{ course._id }}" class="back-link"><png-icon name="arrow-left" size="16"></png-icon> {{ course.title }}</a>
      <div class="reading-crumb">{{ mod.title }}</div>
      <h1><png-icon name="book-open" size="26"></png-icon> {{ lesson.title }}</h1>
      {% if lesson.estMinutes %}<span class="reading-time"><png-icon name="clock" size="15"></png-icon> ใช้เวลาอ่าน ~{{ lesson.estMinutes }} นาที</span>{% endif %}
    </div>

    {% for section in lesson.sections %}
    <section class="reading-section">
      {% if section.heading %}<h2>{{ section.heading }}</h2>{% endif %}
      {% if section.body %}<div class="prose">{{ section.body | markdown | safe }}</div>{% endif %}
      {% if section.image %}<figure class="reading-figure"><img src="{{ section.image }}" alt="{{ section.heading }}"></figure>{% endif %}
    </section>
    {% endfor %}

    <png-lesson-footer
      course-id="{{ course._id }}" m="{{ m }}" l="{{ l }}"
      {% if prev %}prev-href="/learn/{{ course._id }}/{{ prev.m }}/{{ prev.l }}"{% endif %}
      {% if next %}next-href="/learn/{{ course._id }}/{{ next.m }}/{{ next.l }}"{% endif %}
      {% if completed %}completed{% endif %}></png-lesson-footer>
  </article>
</div>
{% endblock %}
