{% extends "base.njk" %}
{% block title %}ลืมรหัสผ่าน — Pingable{% endblock %}

{% block content %}
<png-auth>
  <aside class="auth-brand">
    <png-eyebrow live>Pingable</png-eyebrow>
    <h2>ลืมรหัสผ่าน? ไม่เป็นไร</h2>
    <p>บอกอีเมลที่ใช้สมัคร เราจะส่งลิงก์สำหรับตั้งรหัสผ่านใหม่ให้ทางอีเมล</p>
    <png-terminal title="auth — recovery">
      <p><span class="prompt">$</span> request-reset --email you@example.com</p>
      <p class="out">Sending recovery link...</p>
      <p class="out"><span class="ok">✓ check your inbox</span></p>
      <p><span class="prompt">$</span> <span class="cursor">_</span></p>
    </png-terminal>
  </aside>

  <div class="auth-card">
    <h2>ลืมรหัสผ่าน</h2>
    <p class="auth-sub">กรอกอีเมลที่ใช้สมัคร เราจะส่งลิงก์ตั้งรหัสผ่านใหม่ให้ (ใช้ได้ 1 ชั่วโมง)</p>
    {% if info %}
      <div class="alert alert-success">{{ info }}</div>
    {% endif %}
    {% if error %}
      <div class="alert alert-error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/auth/forgot-password">
      <div class="form-group">
        <label for="email">อีเมล</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
      </div>
      <button type="submit" class="btn btn-primary btn-block" data-submit>ส่งลิงก์ตั้งรหัสผ่านใหม่</button>
    </form>
    <p class="auth-link">นึกรหัสผ่านออกแล้ว? <a href="/auth/login">เข้าสู่ระบบ</a></p>
  </div>
</png-auth>
{% endblock %}

{% block scripts %}<script type="module" src="/js/auth.js"></script>{% endblock %}
