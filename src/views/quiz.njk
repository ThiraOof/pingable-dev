{% extends "base.njk" %}
{% block title %}{{ lesson.title }} — Pingable{% endblock %}

{% block content %}
<div class="learn-layout">
  <article class="quiz">
    <div class="reading-head">
      <a href="/courses/{{ course._id }}" class="back-link"><png-icon name="arrow-left" size="16"></png-icon> {{ course.title }}</a>
      <div class="reading-crumb">{{ mod.title }}</div>
      <h1><png-icon name="help" size="26"></png-icon> {{ lesson.title }}</h1>
      <span class="reading-time">{{ lesson.questions | length }} ข้อ · ต้องได้ {{ lesson.passThreshold or 60 }}% จึงผ่าน</span>
    </div>

    <png-quiz course-id="{{ course._id }}" m="{{ m }}" l="{{ l }}" threshold="{{ lesson.passThreshold or 60 }}">
      <script type="application/json">
{ "questions": [
{% for q in lesson.questions -%}
  { "promptHtml": {{ (q.prompt | markdown) | dump | safe }},
    "multi": {{ "true" if (q.answer | length > 1) else "false" }},
    "choices": {{ q.choices | dump | safe }} }{{ "," if not loop.last }}
{% endfor %}
] }
      </script>
    </png-quiz>
  </article>
</div>
{% endblock %}
