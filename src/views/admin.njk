{% extends "base.njk" %}
{% block title %}Admin — Pingable{% endblock %}

{% block content %}
<div class="admin-wrap">
  <h1 class="admin-title">Admin Panel</h1>

  {% if notice %}
  <div class="admin-notice admin-notice-{{ notice.kind }}">{{ notice.text }}</div>
  {% endif %}

  {# ── Stats ── #}
  <div class="admin-stats">
    <div class="admin-stat">
      <strong>{{ stats.totalUsers }}</strong>
      <span>ผู้ใช้ทั้งหมด</span>
    </div>
    <div class="admin-stat">
      <strong>{{ stats.adminCount }}</strong>
      <span>Admin</span>
    </div>
    <div class="admin-stat">
      <strong>{{ stats.activeSessions }}</strong>
      <span>Lab กำลังใช้งาน</span>
    </div>
    <div class="admin-stat">
      <strong>{{ stats.totalCourses }}</strong>
      <span>คอร์สที่เผยแพร่</span>
    </div>
    <div class="admin-stat">
      <strong>{{ stats.totalLessonsDone }}</strong>
      <span>บทเรียนที่จบ (รวม)</span>
    </div>
  </div>

  {# ── Active Lab Sessions ── #}
  <section class="admin-section">
    <div class="admin-section-head">
      <h2>Lab Sessions ที่ใช้งานอยู่
        <span class="admin-badge">{{ sessionRows | length }}</span>
      </h2>
      <form method="POST" action="/admin/gns3/clean-orphans"
            onsubmit="return confirm('เคลียร์ orphaned GNS3 project ที่ไม่มี session อ้างอิง (อายุเกิน 10 นาที) ใช่ไหม?')">
        <button type="submit" class="admin-btn">เคลียร์ orphaned projects</button>
      </form>
    </div>
    {% if sessionRows.length %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ผู้ใช้</th>
            <th>คอร์ส</th>
            <th>สถานะ</th>
            <th>Idle (นาที)</th>
            <th>Project ID</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for s in sessionRows %}
          <tr>
            <td>{{ s.user.username if s.user else '—' }}</td>
            <td>{{ s.course.title if s.course else '—' }}</td>
            <td>
              <span class="status-chip status-{{ s.status }}">{{ s.status }}</span>
            </td>
            <td class="{% if s.idleMinutes >= 30 %}idle-warn{% endif %}">
              {{ s.idleMinutes }}
            </td>
            <td class="mono">{{ s.projectId | truncate(12, true, '') if s.projectId else '—' }}</td>
            <td>
              <form method="POST" action="/admin/sessions/{{ s._id }}/stop"
                    onsubmit="return confirm('หยุด lab ของ {{ s.user.username if s.user else 'user' }} ใช่ไหม?')">
                <button type="submit" class="admin-btn-danger">หยุด</button>
              </form>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p class="admin-empty">ไม่มี lab session ที่ใช้งานอยู่</p>
    {% endif %}
  </section>

  {# ── Lab difficulty ── #}
  <section class="admin-section">
    <h2>สถิติการตรวจ Lab (เรียงจากผ่านยากสุด)
      <span class="admin-badge">{{ labRows | length }}</span>
    </h2>
    {% if labRows.length %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Lab</th>
            <th>คอร์ส</th>
            <th>ครั้งที่ตรวจ</th>
            <th>ผู้เรียน</th>
            <th>อัตราผ่าน</th>
            <th>คะแนนเฉลี่ย</th>
          </tr>
        </thead>
        <tbody>
          {% for r in labRows %}
          <tr>
            <td><strong>{{ r.labTitle }}</strong></td>
            <td class="muted">{{ r.courseTitle }}</td>
            <td>{{ r.attempts }}</td>
            <td>{{ r.userCount }}</td>
            <td class="{% if r.passRate < 50 %}idle-warn{% endif %}">{{ r.passRate }}%</td>
            <td>{{ r.avgPct }}%</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <p class="admin-empty" style="margin-top:8px">อัตราผ่านต่ำ = โจทย์/คำใบ้อาจยากเกินไป หรือเช็คเข้มเกิน — ใช้ตัดสินใจปรับเนื้อหา</p>
    {% else %}
    <p class="admin-empty">ยังไม่มีการตรวจ lab</p>
    {% endif %}
  </section>

  {# ── Courses ── #}
  <section class="admin-section">
    <h2>คอร์ส
      <span class="admin-badge">{{ courses | length }}</span>
    </h2>
    {% if courses.length %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>คอร์ส</th>
            <th>Track</th>
            <th>ระดับ</th>
            <th>สถานะ</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for c in courses %}
          <tr>
            <td><strong>{{ c.title }}</strong></td>
            <td class="muted">{{ c.track or '—' }}</td>
            <td class="muted">{{ c.level }}</td>
            <td>
              {% if c.published %}
                <span class="status-chip status-ready">เผยแพร่</span>
              {% else %}
                <span class="role-chip role-student">ซ่อน</span>
              {% endif %}
            </td>
            <td>
              {% if c.published %}
              <form method="POST" action="/admin/courses/{{ c._id }}/publish"
                    onsubmit="return confirm('ซ่อนคอร์ส {{ c.title }} จากแคตตาล็อก ใช่ไหม?')">
                <input type="hidden" name="published" value="false">
                <button type="submit" class="admin-btn-danger">ซ่อน</button>
              </form>
              {% else %}
              <form method="POST" action="/admin/courses/{{ c._id }}/publish">
                <input type="hidden" name="published" value="true">
                <button type="submit" class="admin-btn">เผยแพร่</button>
              </form>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <p class="admin-empty">ยังไม่มีคอร์ส</p>
    {% endif %}
  </section>

  {# ── Users ── #}
  <section class="admin-section">
    <h2>ผู้ใช้ทั้งหมด
      <span class="admin-badge">{{ pagination.totalUsers }}</span>
    </h2>
    {% if userRows.length %}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>สมัครวันที่</th>
            <th>บทเรียนจบ</th>
            <th>แล็บผ่าน</th>
            <th>แบบทดสอบผ่าน</th>
            <th>Lab ใช้งาน</th>
            <th>สิทธิ์</th>
          </tr>
        </thead>
        <tbody>
          {% for u in userRows %}
          <tr>
            <td><strong>{{ u.username }}</strong></td>
            <td class="muted">{{ u.email }}</td>
            <td>
              <span class="role-chip role-{{ u.role }}">{{ u.role }}</span>
            </td>
            <td class="muted">{{ u.createdAt | thaidate }}</td>
            <td>{{ u.lessonsDone }}</td>
            <td>{{ u.labsPassed }}</td>
            <td>{{ u.quizzesPassed }}</td>
            <td>{% if u.hasActiveSession %}<span class="status-chip status-ready">●</span>{% else %}—{% endif %}</td>
            <td>
              {% if u._id | string == user.id | string %}
                <span class="muted">คุณ</span>
              {% elif u.role == 'admin' %}
                <form method="POST" action="/admin/users/{{ u._id }}/role"
                      onsubmit="return confirm('ถอดสิทธิ์ admin ของ {{ u.username }} ใช่ไหม?')">
                  <input type="hidden" name="role" value="student">
                  <button type="submit" class="admin-btn-danger">ถอด admin</button>
                </form>
              {% else %}
                <form method="POST" action="/admin/users/{{ u._id }}/role"
                      onsubmit="return confirm('ตั้ง {{ u.username }} เป็น admin ใช่ไหม?')">
                  <input type="hidden" name="role" value="admin">
                  <button type="submit" class="admin-btn">ตั้งเป็น admin</button>
                </form>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% if pagination.totalPages > 1 %}
    <nav class="admin-pager" aria-label="แบ่งหน้าผู้ใช้">
      {% if pagination.page > 1 %}
      <a href="/admin?page={{ pagination.page - 1 }}" class="admin-btn">‹ ก่อนหน้า</a>
      {% else %}
      <span class="admin-btn admin-btn-disabled">‹ ก่อนหน้า</span>
      {% endif %}
      <span class="admin-pager-info">หน้า {{ pagination.page }} / {{ pagination.totalPages }}</span>
      {% if pagination.page < pagination.totalPages %}
      <a href="/admin?page={{ pagination.page + 1 }}" class="admin-btn">ถัดไป ›</a>
      {% else %}
      <span class="admin-btn admin-btn-disabled">ถัดไป ›</span>
      {% endif %}
    </nav>
    {% endif %}
    {% else %}
    <p class="admin-empty">ยังไม่มีผู้ใช้</p>
    {% endif %}
  </section>
</div>
{% endblock %}
