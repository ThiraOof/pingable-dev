{% extends "base.njk" %}
{% block title %}ตั้งค่าบัญชี — Pingable{% endblock %}

{% block content %}
<png-page-header title="ตั้งค่าบัญชี" subtitle="จัดการข้อมูลบัญชีและรหัสผ่านของคุณ"></png-page-header>

<div class="settings-wrap">
  <div class="auth-card">
    <h2>ข้อมูลบัญชี</h2>
    <p class="auth-sub">สมาชิกตั้งแต่ {{ account.createdAt | thaidate }}</p>
    <div class="form-group">
      <label>ชื่อผู้ใช้</label>
      <input type="text" value="{{ account.username }}" disabled>
    </div>
    <div class="form-group">
      <label>อีเมล</label>
      <input type="email" value="{{ account.email }}" disabled>
      {% if account.emailVerified %}
        <p class="field-note ok">✓ ยืนยันอีเมลแล้ว</p>
      {% else %}
        <p class="field-note">ยังไม่ได้ยืนยันอีเมล — เช็คกล่องจดหมายของคุณ</p>
      {% endif %}
    </div>
  </div>

  <div class="auth-card">
    <h2>เป้าหมายการเรียน</h2>
    <p class="auth-sub">ใช้จัดลำดับ "คอร์สถัดไปที่น่าสนใจ" บนแดชบอร์ดให้ตรงกับเส้นทางของคุณ</p>
    <form method="POST" action="/auth/settings/goal">
      <div class="form-group">
        <label for="goal">เป้าหมายของคุณ</label>
        <select id="goal" name="goal">
          <option value="">— ยังไม่ระบุ —</option>
          {% for key, g in goals %}
          <option value="{{ key }}" {% if account.goal == key %}selected{% endif %}>{{ g.label }}</option>
          {% endfor %}
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-block">บันทึกเป้าหมาย</button>
    </form>
  </div>

  <div class="auth-card">
    <h2>ความเป็นส่วนตัว</h2>
    <p class="auth-sub">ควบคุมการแสดงข้อมูลของคุณต่อสาธารณะ</p>
    <form method="POST" action="/auth/settings/privacy">
      <label class="toggle-row">
        <input type="checkbox" name="hideFromLeaderboard" {% if account.hideFromLeaderboard %}checked{% endif %}>
        <span>ซ่อนชื่อของฉันจาก<a href="/leaderboard">ตารางอันดับ</a> (แสดงเป็น "ผู้ไม่ประสงค์ออกนาม")</span>
      </label>
      <label class="toggle-row">
        <input type="checkbox" name="profilePublic" {% if account.profilePublic %}checked{% endif %}>
        <span>เปิดโปรไฟล์สาธารณะที่ <a href="/u/{{ account.username }}">/u/{{ account.username }}</a> (โชว์ตำแหน่ง, badge, คอร์สที่จบ — แนบใน resume ได้)</span>
      </label>
      <button type="submit" class="btn btn-secondary btn-block">บันทึก</button>
    </form>
  </div>

  <div class="auth-card">
    <h2>เปลี่ยนรหัสผ่าน</h2>
    <p class="auth-sub">รหัสผ่านใหม่อย่างน้อย 8 ตัวอักษร มีตัวอักษรและตัวเลขอย่างน้อยอย่างละ 1 ตัว</p>
    {% if info %}
      <div class="alert alert-success">{{ info }}</div>
    {% endif %}
    {% if error %}
      <div class="alert alert-error">{{ error }}</div>
    {% endif %}
    <form method="POST" action="/auth/settings/password">
      <div class="form-group">
        <label for="currentPassword">รหัสผ่านปัจจุบัน</label>
        <div class="pw-wrap">
          <input type="password" id="currentPassword" name="currentPassword" required placeholder="••••••••" autocomplete="current-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="currentPassword">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label for="password">รหัสผ่านใหม่</label>
        <div class="pw-wrap">
          <input type="password" id="password" name="password" required placeholder="อย่างน้อย 8 ตัวอักษร" minlength="8" autocomplete="new-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="password">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label for="confirmPassword">ยืนยันรหัสผ่านใหม่</label>
        <div class="pw-wrap">
          <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="••••••••" autocomplete="new-password">
          <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" data-target="confirmPassword">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block" data-submit>บันทึกรหัสผ่านใหม่</button>
    </form>
  </div>
</div>
{% endblock %}

{% block scripts %}<script type="module" src="/js/auth.js"></script>{% endblock %}
