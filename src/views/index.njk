{% extends "base.njk" %}
{% block title %}Pingable — เรียน Network ผ่าน Lab จริง{% endblock %}

{% block content %}
<png-hero>
  <div class="hero-content">
    <png-eyebrow live>Lab พร้อมใช้งานแบบเรียลไทม์</png-eyebrow>
    <h1>เรียน Network<br><span class="highlight">ผ่าน Lab จริงในเบราว์เซอร์</span></h1>
    <p>ฝึกทำ Lab บน Router/Switch จำลองผ่าน GNS3 พร้อมระบบตรวจคำตอบอัตโนมัติ โดยไม่ต้องติดตั้งอะไรเพิ่ม</p>
    <div class="hero-actions">
      {% if user %}
        <png-button variant="primary" size="lg" href="/courses" icon="layers">ดูคอร์สเรียน</png-button>
      {% else %}
        <png-button variant="primary" size="lg" href="/auth/register" icon="play">เริ่มเรียนฟรี</png-button>
        <png-button variant="outline" size="lg" href="/auth/login">เข้าสู่ระบบ</png-button>
      {% endif %}
    </div>
    <div class="hero-stats">
      <png-stat kind="hero" value="GNS3" label="Topology จริง"></png-stat>
      <png-stat kind="hero" value="Auto" label="ตรวจคำตอบทันที"></png-stat>
      <png-stat kind="hero" value="0฿" label="เริ่มต้นฟรี"></png-stat>
    </div>
  </div>
  <div class="hero-visual">
    <png-terminal title="R1 — console">
      <p><span class="prompt">R1#</span> show ip interface brief</p>
      <p class="out">Interface          IP-Address    Status</p>
      <p class="out">Gig0/0             192.168.1.1   <span class="ok">up</span></p>
      <p class="out">Gig0/1             10.0.0.1      <span class="ok">up</span></p>
      <p><span class="prompt">R1#</span> ping 10.0.0.2</p>
      <p class="out">!!!!! <span class="ok">Success rate is 100 percent</span></p>
      <p><span class="prompt">R1#</span> <span class="cursor">_</span></p>
    </png-terminal>
  </div>
</png-hero>

<png-signal-band>
  <png-stat kind="signal" icon="route" value="20+" label="Hands-on Lab"></png-stat>
  <png-stat kind="signal" icon="gauge" value="< 30s" label="Provision Topology"></png-stat>
  <png-stat kind="signal" icon="badge-check" value="Auto" label="ตรวจจากคอนโซลจริง"></png-stat>
  <png-stat kind="signal" icon="wifi" value="100%" label="รันบนเบราว์เซอร์"></png-stat>
</png-signal-band>

<png-features>
  <png-feature icon="zap" heading="เริ่มได้ทันที">กด Start Lab แล้วระบบ provision Topology อัตโนมัติภายในไม่กี่วินาที</png-feature>
  <png-feature icon="server" heading="อุปกรณ์จริง">โต้ตอบกับ Router/Switch ผ่าน GNS3 Web-UI ในเบราว์เซอร์ ไม่ต้องลง SSH/Telnet</png-feature>
  <png-feature icon="badge-check" heading="ตรวจอัตโนมัติ">ระบบ grade ผลลัพธ์จากคอนโซลจริง พร้อมคะแนนรายข้อและ output ที่ตรวจสอบได้</png-feature>
  <png-feature icon="wallet" heading="ประหยัด">เซิร์ฟเวอร์เปิด-ปิดตามการใช้งาน คืนทรัพยากรเมื่อจบ จ่ายเฉพาะที่ใช้จริง</png-feature>
</png-features>

<png-cta heading="พร้อมลงมือทำ Lab แรกหรือยัง?" text="สมัครฟรี แล้วเริ่มฝึก Network จาก Topology จริงได้ทันที">
  {% if user %}
    <png-button variant="primary" size="lg" href="/courses" icon="arrow-right">เลือกคอร์ส</png-button>
  {% else %}
    <png-button variant="primary" size="lg" href="/auth/register" icon="play">เริ่มเรียนฟรี</png-button>
  {% endif %}
</png-cta>
{% endblock %}
