{% extends "base.njk" %}
{% block title %}Pingable Dev — เรียน Network ผ่าน Lab จริง{% endblock %}

{% block content %}
<section class="hero">
  <div class="hero-content">
    <h1>เรียน Network<br><span class="highlight">ผ่าน Lab จริงในเบราว์เซอร์</span></h1>
    <p>ฝึกทำ Lab บน Router/Switch จำลองผ่าน GNS3 โดยไม่ต้องติดตั้งอะไรเพิ่ม</p>
    <div class="hero-actions">
      {% if user %}
        <a href="/courses" class="btn btn-primary btn-lg">ดูคอร์สเรียน</a>
      {% else %}
        <a href="/auth/register" class="btn btn-primary btn-lg">เริ่มเรียนฟรี</a>
        <a href="/auth/login" class="btn btn-outline btn-lg">เข้าสู่ระบบ</a>
      {% endif %}
    </div>
  </div>
  <div class="hero-visual">
    <div class="terminal-preview">
      <div class="terminal-bar">
        <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
        <span class="terminal-title">Router1#</span>
      </div>
      <div class="terminal-body">
        <p><span class="prompt">Router1#</span> show ip interface brief</p>
        <p>Interface&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;IP-Address&nbsp;&nbsp;&nbsp;OK?&nbsp;Status</p>
        <p>GigabitEthernet0/0&nbsp;192.168.1.1&nbsp;&nbsp;YES up</p>
        <p>GigabitEthernet0/1&nbsp;10.0.0.1&nbsp;&nbsp;&nbsp;&nbsp;YES up</p>
        <p><span class="prompt">Router1#</span> <span class="cursor">_</span></p>
      </div>
    </div>
  </div>
</section>

<section class="features">
  <div class="feature-card">
    <div class="feature-icon">⚡</div>
    <h3>เริ่มได้ทันที</h3>
    <p>กด Start Lab แล้วระบบสร้าง Topology อัตโนมัติภายในไม่กี่วินาที</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon">🖥️</div>
    <h3>Terminal ในเบราว์เซอร์</h3>
    <p>พิมพ์คำสั่ง CLI ได้เลย ไม่ต้องติดตั้ง SSH Client หรือ Telnet</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon">💰</div>
    <h3>ประหยัดค่าใช้จ่าย</h3>
    <p>เซิร์ฟเวอร์เปิด-ปิดตามการใช้งาน จ่ายเฉพาะเวลาที่ใช้จริง</p>
  </div>
</section>
{% endblock %}
