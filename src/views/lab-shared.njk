{% extends "base.njk" %}
{% block title %}ผลการตรวจ Lab{% if course %} — {{ course.title }}{% endif %} · Pingable{% endblock %}

{% block head %}
{# Open Graph: ทำให้ลิงก์ที่แชร์ลง LINE/Facebook ขึ้น preview เป็นการ์ดผลคะแนน #}
<meta property="og:type" content="website">
<meta property="og:site_name" content="Pingable">
<meta property="og:title" content="{% if attempt.passed %}ผ่าน{% else %}ลุย{% endif %}{% if labTitle %} {{ labTitle }}{% else %} Lab{% endif %} ได้ {{ attempt.pct }}% บน Pingable">
<meta property="og:description" content="{{ attempt.score }}/{{ attempt.total }} คะแนน{% if course %} · {{ course.title }}{% endif %} — ฝึกทำ Network Lab บนอุปกรณ์จริงผ่านเบราว์เซอร์ ฟรี">
<meta property="og:image" content="{{ origin }}/lab/shared/{{ attempt.shareToken }}/card.png">
<meta property="og:image:type" content="image/png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="ทำ Lab ได้ {{ attempt.pct }}% บน Pingable">
<meta name="twitter:description" content="{{ attempt.score }}/{{ attempt.total }} คะแนน{% if labTitle %} · {{ labTitle }}{% endif %} — ฝึก Network Lab บนอุปกรณ์จริง ฟรี">
<meta name="twitter:image" content="{{ origin }}/lab/shared/{{ attempt.shareToken }}/card.png">
{% endblock %}

{% block content %}
<div class="shared-wrap">

  <div class="shared-header {{ 'pass' if attempt.passed else 'fail' }}">
    <div class="shared-verdict-row">
      {% if attempt.passed %}
      <png-icon name="badge-check" size="28"></png-icon>
      <span class="shared-verdict pass">ผ่านแล้ว!</span>
      {% else %}
      <png-icon name="x-circle" size="28"></png-icon>
      <span class="shared-verdict fail">ยังไม่ผ่าน</span>
      {% endif %}
    </div>
    <div class="shared-score {{ 'pass' if attempt.passed else 'fail' }}">{{ attempt.pct }}%</div>
    <p class="shared-meta">{{ attempt.score }} จาก {{ attempt.total }} คะแนน</p>
    {% if course %}
    <p class="shared-course">{{ course.title }}{% if labTitle %} — {{ labTitle }}{% endif %}</p>
    {% endif %}
    <p class="shared-date">{{ attempt.at | thaidate }}</p>
  </div>

  {% if attempt.results and attempt.results.length %}
  <div class="shared-results">
    <h2>ผลการตรวจรายข้อ</h2>
    <ul class="shared-list">
      {% for r in attempt.results %}
      <li class="shared-item {{ 'pass' if r.passed else 'fail' }}">
        <span class="shared-icon">{% if r.passed %}✓{% else %}✕{% endif %}</span>
        <span class="shared-desc">{{ r.description }}</span>
        <span class="shared-pts">{{ r.points if r.passed else 0 }} / {{ r.points }} pt</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <div class="shared-footer">
    <p class="shared-footer-note">ผลการตรวจนี้แชร์จาก Pingable — ฝึกทำ Network Lab บน Router/Switch จริงผ่านเบราว์เซอร์ ตรวจคำตอบอัตโนมัติ เรียนฟรี</p>
    <png-button variant="primary" href="/auth/register" icon-end="arrow-right">เริ่มเรียนฟรี</png-button>
    <png-button variant="secondary" href="/courses">ดูคอร์สทั้งหมด</png-button>
  </div>

</div>
{% endblock %}
