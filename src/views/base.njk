<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Pingable{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Sans+Thai:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script type="module" src="/js/components/index.js"></script>
  {% block head %}{% endblock %}
</head>
<body>
  <png-navbar{% if user %} username="{{ user.username }}"{% endif %}></png-navbar>

  <main>
    {% block content %}{% endblock %}
  </main>

  <png-footer></png-footer>

  {% block scripts %}{% endblock %}
</body>
</html>
