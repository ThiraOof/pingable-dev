<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Pingable{% endblock %}</title>
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32.png">
  <link rel="apple-touch-icon" href="/img/favicon-180.png">
  {% set ogDesc = "เรียน Network ผ่าน Lab จริงในเบราว์เซอร์ — ฝึกบน Router/Switch จริงผ่าน GNS3 ระบบตรวจคำตอบอัตโนมัติ" %}
  <meta name="description" content="{{ ogDesc }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pingable">
  <meta property="og:title" content="{% block ogtitle %}Pingable — เรียน Network ผ่าน Lab จริงในเบราว์เซอร์{% endblock %}">
  <meta property="og:description" content="{{ ogDesc }}">
  <meta property="og:image" content="{{ origin }}/img/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="{{ origin }}/img/og-image.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Sans+Thai:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script type="module" src="{% if isProd %}/js/bundle.js{% else %}/js/components/index.js{% endif %}"></script>
  {% block head %}{% endblock %}
</head>
<body>
  <a href="#main-content" class="skip-link">ข้ามไปยังเนื้อหาหลัก</a>
  <png-navbar{% if user %} username="{{ user.username }}"{% endif %}{% if eventsActive %} events-active="1"{% endif %}></png-navbar>

  {% if user and not user.emailVerified %}
  <div class="verify-banner" role="alert">
    <span class="verify-banner-text">
      <png-icon name="mail" size="15"></png-icon>
      กรุณายืนยันอีเมล <strong>{{ user.email }}</strong> — เช็คกล่องจดหมายของคุณ
    </span>
    <form method="POST" action="/auth/resend" class="verify-banner-form">
      <button type="submit" class="verify-banner-btn">ส่งอีเมลอีกครั้ง</button>
    </form>
  </div>
  {% endif %}

  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  <png-footer></png-footer>

  {% block scripts %}{% endblock %}
</body>
</html>
