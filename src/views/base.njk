<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Pingable Dev{% endblock %}</title>
  <link rel="stylesheet" href="/css/styles.css">
  {% block head %}{% endblock %}
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-brand">🌐 Pingable Dev</a>
    <div class="nav-links">
      {% if user %}
        <a href="/courses">คอร์สเรียน</a>
        <span class="nav-user">{{ user.username }}</span>
        <form method="POST" action="/auth/logout" style="display:inline">
          <button type="submit" class="btn-link">ออกจากระบบ</button>
        </form>
      {% else %}
        <a href="/auth/login">เข้าสู่ระบบ</a>
        <a href="/auth/register" class="btn btn-primary">สมัครสมาชิก</a>
      {% endif %}
    </div>
  </nav>

  <main>
    {% block content %}{% endblock %}
  </main>

  <footer class="footer">
    <p>Pingable Dev &copy; 2026 — Network Labs ออนไลน์</p>
  </footer>

  {% block scripts %}{% endblock %}
</body>
</html>
